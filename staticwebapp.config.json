{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/img/*",
      "/style.css",
      "/script.js",
      "/manifest.json",
      "/*.{ico,png,jpg,jpeg,gif,svg,avif,webp,css,js,json,xml,woff,woff2,ttf}"
    ]
  },
  "mimeTypes": {
    ".css": "text/css",
    ".html": "text/html",
    ".js": "application/javascript",
    ".json": "application/json",
    ".avif": "image/avif"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}